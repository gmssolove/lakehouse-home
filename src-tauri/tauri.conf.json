{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "키사라기고교",
  "version": "0.1.0",
  "identifier": "me.jp.lakehouse.kisaragi",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://127.0.0.1:3004/vn",
    "beforeDevCommand": "node scripts/tauri-ensure-dev.mjs",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "키사라기고교",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "url": "vn/index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
