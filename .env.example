# Cloudflare R2 (S3-compatible API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lakehouse-images

# 업로드 후 클라이언트에 돌려줄 공개 URL prefix (끝 슬래시 없이)
# 예: https://lakehouse-r2-upload.gmssolove.workers.dev/file
# 또는 커스텀 CDN: https://img.lakehouse.me.kr
R2_PUBLIC_BASE_URL=

# 선택: 설정 시 업로드 API에 토큰 필요
R2_UPLOAD_TOKEN=

# YouTube Data API v3 (서버 전용 — Scrap 재생시간·업로드일)
YOUTUBE_API_KEY=
